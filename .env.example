# ============================================================
# Environment Configuration Template
# Copy to .env and fill in your API keys:  cp .env.example .env
# ============================================================

# ── Market Data APIs ────────────────────────────────────────
# At minimum, configure the providers you plan to use.

# Polygon.io (real-time and historical market data)
# POLYGON_API_KEY=your-polygon-key-here

# Alpha Vantage (stock, forex, crypto data)
# ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# FRED (Federal Reserve Economic Data)
# FRED_API_KEY=your-fred-key-here

# Quandl / Nasdaq Data Link
# QUANDL_API_KEY=your-quandl-key-here

# Note: Yahoo Finance (yfinance) does not require an API key.

# ── AI / LLM Configuration ─────────────────────────────────
# For AI-powered features (explanations, analysis, content generation)

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_PROD_MODEL=gpt-4o

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379/0

# ── Application ─────────────────────────────────────────────
# APP_ENV=development
# DEBUG=true
# LOG_LEVEL=INFO
